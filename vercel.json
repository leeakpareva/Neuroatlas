{
  "framework": null,
  "buildCommand": null,
  "outputDirectory": ".",
  "functions": {
    "api/chat.js": { "maxDuration": 60 },
    "api/tts.js": { "maxDuration": 60 }
  },
  "headers": [
    {
      "source": "/(.*).(glb|gltf|bin|wasm|png|jpg|jpeg|webp|gif|woff2|woff|ico)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }]
    },
    {
      "source": "/(.*).(js|css|html|json|webmanifest)",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, must-revalidate" }]
    },
    {
      "source": "/",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, must-revalidate" }]
    }
  ]
}
